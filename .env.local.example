# ─── Supabase ──────────────────────────────────────────────────────────────
# Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only — used by the Stripe webhook

# ─── Stripe ────────────────────────────────────────────────────────────────
# Developers → API keys
STRIPE_SECRET_KEY=
# Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
# Products → TempoRead Pro → price IDs (monthly + annual)
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
